# Rogue Repo — environment variables
# Copy to .env and fill in values

# PostgreSQL (required for auth, ledger, entitlements)
DATABASE_URL=postgres://user:pass@localhost:5432/rogue_repo

# Session signing key — REQUIRED in production (>= 32 chars)
# In debug builds, a random key is generated if not set
SESSION_SECRET=

# Vault encryption key (32 bytes hex for AES-256-GCM)
ROGUE_VAULT_KEY=

# Email verification via Resend (optional — logs link to console if not set)
RESEND_API_KEY=
RESEND_FROM=Rogue Repo <noreply@roguerepo.io>

# Base URL for verification links
REPO_BASE_URL=http://localhost:3001

# Approuter registration (optional)
APPROUTER_URL=http://127.0.0.1:8080
REPO_HOSTNAMES=roguerepo.io,www.roguerepo.io
REPO_BACKEND_URL=http://127.0.0.1:3001

# ISO 8583 bank/processor TCP endpoint (optional — skips bank send if not set)
SWITCH_HOST=
SWITCH_PORT=8583
SWITCH_TIMEOUT_MS=10000

# Server
PORT=3001
RUST_LOG=info
