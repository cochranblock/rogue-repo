<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="Rogue Runner" Language="1033" Version="0.1.0" Manufacturer="Rogue Repo" UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
    <Package Id="*" InstallerVersion="500" Compressed="yes" Description="Rogue Runner — 1000-level endless runner" />
    <Media Id="1" Cabinet="RogueRunner.cab" EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="Rogue Runner" Level="1">
      <ComponentRef Id="RogueRunnerComponent" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder" Name="PFiles">
        <Directory Id="INSTALLFOLDER" Name="Rogue Runner">
          <Component Id="RogueRunnerComponent" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
            <File Id="RogueRunnerExe" Source="$(var.SourceDir)/rogue-runner.exe" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>
  </Product>
</Wix>
