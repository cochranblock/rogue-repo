/src/agent_loop.rs @cochranblock
/src/tools.rs      @cochranblock
/src/node_cmd.rs   @cochranblock
/src/cargo_cmd.rs  @cochranblock
/src/serve.rs      @cochranblock
/src/gui.rs        @cochranblock

# Tests — all contributors
/tests/            @cochranblock

# Docs — shared ownership
/docs/             @cochranblock @community
README.md          @cochranblock
CONTRIBUTING.md    @cochranblock

# Web client
/src/web.rs        @cochranblock
/kova-web/         @cochranblock

# Swarm / cluster
/src/c2.rs         @cochranblock

# Config & storage
/src/config.rs     @cochranblock
